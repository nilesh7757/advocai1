# Database Configuration
MONGO_URI=mongodb+srv://<username>:<password>@cluster.xxxxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=legal_document_navigator_db
SECRET_KEY=your-django-secret-key-here

# API Keys (needed for AI features)
GEMINI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# Cloudinary Configuration (needed for lawyer verification documents and uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google OAuth (optional, for Google Sign-In)
GOOGLE_CLIENT_ID=

# Email Settings (optional, for OTP email verification)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
